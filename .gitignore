# Debug Utils Package .gitignore

# =============================================================================
# Debug-specific artifacts (generated by this package)
# =============================================================================

# Debug sessions and captured data
debug_session*/
debug_output/
debug_workspace/
*_debug_session/
captured_calls.json
session_summary.json

# Generated test scripts (unless you want to commit them)
test_*.py
*_test.py
debug_scripts/
scripts/

# Serialized data files
*.debug_data
*_args.json
*_output.json
serialized_*/

# Debug artifacts
debug_artifacts/
debug_reports/
benchmark_results/

# =============================================================================
# Python
# =============================================================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# Translations
*.mo
*.pot

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Flask stuff:
instance/
.webassets-cache

# Scrapy stuff:
.scrapy

# Sphinx documentation
docs/_build/

# PyBuilder
.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if having platform-specific dependencies or dependencies
#   having no cross-platform support, pipenv may install dependencies that don't work, or not
#   install all needed dependencies.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is generally recommended to include poetry.lock in version control.
#   This is especially recommended for binary packages to ensure reproducibility, and is more
#   commonly ignored for libraries.
#   https://python-poetry.org/docs/basic-usage/#commit-your-poetrylock-file-to-version-control
#poetry.lock

# pdm
#   Similar to Pipfile.lock, it is generally recommended to include pdm.lock in version control.
#pdm.lock
#   pdm stores project-wide configurations in .pdm.toml, but it is recommended to not include it
#   in version control.
#   https://pdm.fming.dev/#use-with-ide
.pdm.toml

# PEP 582; used by e.g. github.com/David-OConnor/pyflow and github.com/pdm-project/pdm
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# pytype static type analyzer
.pytype/

# Cython debug symbols
cython_debug/

# =============================================================================
# AI/ML Specific
# =============================================================================

# Model files and checkpoints
*.pth
*.pt
*.ckpt
*.h5
*.hdf5
*.pkl
*.pickle
*.joblib
*.model
*.weights
checkpoints/
models/
saved_models/

# Large data files
*.npy
*.npz
*.parquet
*.feather
*.arrow
data/
datasets/
raw_data/
processed_data/
features/

# Tensorboard logs
runs/
logs/
tensorboard_logs/
tb_logs/

# MLflow
mlruns/
mlartifacts/

# Weights & Biases
wandb/

# DVC
.dvc
.dvcignore

# =============================================================================
# Development Tools
# =============================================================================

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# =============================================================================
# Project Specific
# =============================================================================

# Temporary files
tmp/
temp/
*.tmp
*.bak

# Configuration files with secrets
config_local.py
secrets.json
.secrets

# Large example files (keep small examples)
examples/large_*/
examples/data/
examples/models/

# Performance profiling
*.prof
profile_results/

# Documentation builds
docs/build/
docs/_build/

# =============================================================================
# Optional: Uncomment if you want to ignore certain generated artifacts
# =============================================================================

# Uncomment if you don't want to track generated test scripts
# test_*.py
# *_test_script.py

# Uncomment if you don't want to track any debug sessions
# debug_*/
# *_debug_*

# Uncomment if you have large serialized objects you don't want to track
# *.serialized
# serialized_objects/
